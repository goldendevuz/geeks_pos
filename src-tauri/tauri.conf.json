{
  "build": {
    "beforeBuildCommand": "npm run build --prefix frontend",
    "beforeDevCommand": "npm run dev --prefix frontend",
    "devPath": "http://localhost:5173",
    "distDir": "../frontend/dist"
  },
  "package": {
    "productName": "GEEKS POS",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "http": {
        "request": true,
        "scope": [
          "http://127.0.0.1/**",
          "http://localhost/**",
          "https://tauri.localhost/**"
        ]
      },
      "shell": {
        "open": true
      },
      "window": {
        "all": true
      }
    },
    "bundle": {
      "active": true,
      "category": "Business",
      "copyright": "",
      "deb": {
        "depends": []
      },
      "externalBin": [
        "../backend/dist/geeks_pos_backend"
      ],
      "icon": [
        "icons/icon.ico",
        "icons/resized-logo.png",
        "icons/resized-logo (1).png",
        "icons/resized-logo (2).png"
      ],
      "identifier": "uz.geeks.pos",
      "longDescription": "",
      "macOS": {
        "entitlements": null,
        "exceptionDomain": "",
        "frameworks": [],
        "providerShortName": null,
        "signingIdentity": null
      },
      "resources": [
        "../scripts/windows/add-firewall-rule.ps1",
        "../scripts/windows/add-firewall-rule-admin.bat"
      ],
      "shortDescription": "",
      "targets": "all",
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": "",
        "webviewInstallMode": {
          "type": "downloadBootstrapper"
        }
      }
    },
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://127.0.0.1:* http://localhost:* ws://127.0.0.1:* ws://localhost:* https://tauri.localhost 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:"
    },
    "updater": {
      "active": false
    },
    "windows": [
      {
        "alwaysOnTop": false,
        "decorations": true,
        "fullscreen": true,
        "maximized": true,
        "height": 768,
        "resizable": true,
        "title": "GEEKS POS",
        "width": 1366,
        "hiddenTitle": false,
        "center": true
      }
    ]
  }
}
